server {
    listen {{ api_listen_port }};
    server_name {{ api_nginx_urls }};

    root /var/www/public;
    index index.php index.html;

    gzip on;
    gzip_vary on;
    gzip_comp_level 5;
    gzip_min_length 1024;
    gzip_types application/json text/plain text/css application/javascript;

    location ^~ /storage/ {
        alias /var/www/storage/app/public/;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;

        location ~* \.(jpg|jpeg|png|gif|ico|svg|webp|pdf|doc|docx|zip)$ {
            expires 1y;
            add_header Cache-Control "public, immutable";
        }
    }

    location / {
        client_max_body_size 50M;
        fastcgi_param REQUEST_METHOD $request_method;

        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_pass {{ api_php_container }}:{{ php_fpm_port }};
        fastcgi_index index.php;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_param PATH_INFO $fastcgi_path_info;
        fastcgi_buffers 16 16k;
        fastcgi_buffer_size 32k;
    }
}

server {
    listen {{ dav_listen_port }};
    server_name {{ dav_nginx_urls }};

    root /var/www/public;

    client_max_body_size 50M;

    location / {
        include fastcgi_params;
        fastcgi_pass {{ api_dav_container }}:{{ php_fpm_port }};
        fastcgi_index dav.php;
        fastcgi_param SCRIPT_FILENAME $document_root/dav.php;
        fastcgi_param PATH_INFO $fastcgi_path_info;
        fastcgi_buffering off;
        fastcgi_request_buffering off;
    }
}
