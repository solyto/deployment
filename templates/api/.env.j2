PROJECT_NAME={{ project_name }}
DOMAIN={{ api_domain }}
COMPOSE_PROJECT_NAME={{ project_name }}

# User
USER={{ docker_user }}
UID={{ docker_uid }}
GID={{ docker_gid }}

# App
APP_NAME={{ api_domain }}
APP_ENV={{ environment }}
APP_DEBUG={{ debug }}
APP_URL=https://{{ api_domain }}
FRONTEND_URL=https://{{ frontend_domain }}
LANDING_PAGE_URL=https://{{ landing_page_domain }}
APP_TIMEZONE=UTC
LOG_CHANNEL=stderr

# Database
DB_CONNECTION=mariadb
DB_HOST=db-mariadb
DB_PORT=3306
DB_DATABASE=api
DAV_DB_HOST=db-postgres
DAV_DB_PORT=5432
DAV_DB_DATABASE=dav

# Redis
REDIS_CLIENT=phpredis
REDIS_HOST=db-redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_PREFIX=solyto_

# Versions
PHP_VERSION={{ php_version }}

# Misc
TIMEZONE=UTC

PULSE_ENABLED=false
TELESCOPE_ENABLED=false

# AI
AI_BASE_URL={{ ai_base_url }}
AI_MODEL={{ ai_model }}

# Mail
MAILGUN_DOMAIN={{ mail_domain }}
MAIL_FROM_ADDRESS={{ mail_from_address }}
MAIL_FROM_NAME={{ mail_from_name }}
